# ====== MER Analytics Backend — variables de entorno ======
# Copia este archivo como .env y completa los valores.

PORT=4000

# Conexión a PostgreSQL de Neon (neon.tech → Connection string → "Pooled connection")
DATABASE_URL=postgresql://usuario:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Secreto para firmar los tokens de sesión (login propio).
# Genera uno largo y aleatorio, por ejemplo con: openssl rand -base64 48
JWT_SECRET=cambia_esto_por_un_texto_largo_y_secreto

# Clave de IA (Anthropic) para el asistente
ANTHROPIC_API_KEY=sk-ant-...

# Origen permitido del frontend (CORS). Usa * mientras pruebas.
FRONTEND_ORIGIN=*

# Modo demo: true = sin login (tenant demo). En producción: false
DEMO_MODE=false
